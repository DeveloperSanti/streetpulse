generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rango {
  S
  A
  B
  C
  D
}

enum Role {
  piloto
  administrador
}

enum EstadoUsuario {
  activo
  suspendido
  inactivo
}

enum TipoVehiculo {
  auto
  moto
  monopatin_electrico
}

enum TipoCarrera {
  cuarto_milla
  vueltas
  derrape
}

enum EstadoReto {
  pendiente
  aceptado
  rechazado
  en_curso
  completado
  cancelado
}

model User {
  id                 String        @id @default(uuid())
  username           String        @unique
  email              String        @unique
  password           String
  foto_perfil        String?
  rango              Rango         @default(D)
  role               Role          @default(piloto)
  estado             EstadoUsuario @default(activo)
  zona_localidad     String?
  zona_ciudad        String?
  zona_estado        String?
  zona_pais          String?
  victorias          Int           @default(0)
  derrotas           Int           @default(0)
  retos_consecutivos Int           @default(0)
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  vehicles           Vehicle[]
  retos_enviados     Challenge[]   @relation("Retador")
  retos_recibidos    Challenge[]   @relation("Retado")
  retos_ganados      Challenge[]   @relation("Ganador")
  notifications      Notification[]
  refresh_tokens     RefreshToken[]
}

model Vehicle {
  id             String       @id @default(uuid())
  user_id        String
  tipo_vehiculo  TipoVehiculo
  marca          String
  modelo         String
  anio           Int          @map("ano")
  color          String?
  placa          String       @unique
  foto           String?
  modificaciones String?
  activo         Boolean      @default(false)
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  user           User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  retos_retador  Challenge[]  @relation("VehiculoRetador")
  retos_retado   Challenge[]  @relation("VehiculoRetado")
}

model Challenge {
  id                  String     @id @default(uuid())
  retador_id          String
  retado_id           String
  vehiculo_retador_id String
  vehiculo_retado_id  String
  tipo_carrera        TipoCarrera
  estado              EstadoReto  @default(pendiente)
  ganador_id          String?
  ubicacion_acordada  String?
  fecha_acordada      DateTime?
  notas               String?
  notas_resultado     String?
  confirmado_retador  Boolean     @default(false)
  confirmado_retado   Boolean     @default(false)
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt

  retador             User        @relation("Retador", fields: [retador_id], references: [id])
  retado              User        @relation("Retado", fields: [retado_id], references: [id])
  vehiculo_retador    Vehicle     @relation("VehiculoRetador", fields: [vehiculo_retador_id], references: [id])
  vehiculo_retado     Vehicle     @relation("VehiculoRetado", fields: [vehiculo_retado_id], references: [id])
  ganador             User?       @relation("Ganador", fields: [ganador_id], references: [id])
}

model Notification {
  id              String   @id @default(uuid())
  user_id         String
  tipo            String
  titulo          String?
  mensaje         String
  leida           Boolean  @default(false)
  referencia_id   String?
  referencia_tipo String?
  created_at      DateTime @default(now())

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Category {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  activo      Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
